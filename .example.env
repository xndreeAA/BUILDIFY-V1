# ============================================================================
# BUILDIFY V1 - Configuración de Variables de Entorno
# ============================================================================
#
# Copiar este archivo como ".env" en la raíz del proyecto y completar
# con tus valores reales. NUNCA comitear el archivo ".env" a git.
#
# Para desarrollo local, puedes usar los valores de ejemplo.
# Para producción, usar valores seguros y secretos.
#
# ============================================================================

# ============================================================================
# ENTORNO Y SEGURIDAD
# ============================================================================

# Entorno de ejecución: development o production
# En desarrollo: Flask muestra errores detallados y recarga automáticamente
# En producción: Desactiva debug, aplica cookies seguras, requiere HTTPS
FLASK_ENV=development

# Clave secreta para sesiones y CSRF tokens
# Generar algo aleatorio: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# Clave secreta para JWT (tokens de API)
# Generar algo aleatorio: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production

# ============================================================================
# BASE DE DATOS MySQL
# ============================================================================

# Usuario de MySQL
DB_USER=buildify_user

# Contraseña de MySQL
DB_PASSWORD=tu_contraseña_segura

# Host de MySQL (localhost para desarrollo)
# Para producción, usar RDS, Supabase, o servicio gestionado
DB_HOST=localhost

# Puerto de MySQL (por defecto 3306)
DB_PORT=3306

# Nombre de la base de datos
DB_NAME=buildify

# Ejemplo de URL completa (si prefieres usar DATABASE_URL):
# DATABASE_URL=mysql+pymysql://buildify_user:tu_contraseña@localhost:3306/buildify

# ============================================================================
# STRIPE - Procesamiento de Pagos
# ============================================================================

# Clave secreta de Stripe para servidor
# Obtener en: https://dashboard.stripe.com/apikeys
# En testing: sk_test_...
# En producción: sk_live_...
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Clave de webhook de Stripe
# Obtener en: https://dashboard.stripe.com/webhooks
# En testing: whsec_test_...
# En producción: whsec_live_...
STRIPE_WEBHOOK_KEY=whsec_test_your_webhook_key

# URL de éxito después de completar el pago
# El usuario será redirigido aquí cuando el pago sea exitoso
STRIPE_SUCCESS_URL=http://localhost:5000/pagos/success

# URL de cancelación si el usuario cancela el pago
# El usuario será redirigido aquí si cancela el pago
STRIPE_CANCEL_URL=http://localhost:5000/pagos/cancel

# ============================================================================
# SENDGRID - Envío de Emails
# ============================================================================

# API Key de SendGrid para envío de emails
# Obtener en: https://app.sendgrid.com/settings/api_keys
# Crear una clave solo con permisos de "Mail Send"
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# Email remitente para notificaciones
# Este email debe estar verificado en SendGrid
# Usar formato: nombre@dominio.com o "Nombre" <nombre@dominio.com>
SENDGRID_SENDER=noreply@buildify.com

# ============================================================================
# CLOUDINARY - Almacenamiento de Imágenes
# ============================================================================

# Nombre de la nube en Cloudinary
# Obtener en: https://cloudinary.com/console/settings/api
CLOUDINARY_CLOUD_NAME=your_cloud_name

# API Key de Cloudinary
# Obtener en: https://cloudinary.com/console/settings/api
CLOUDINARY_API_KEY=your_cloudinary_api_key

# API Secret de Cloudinary
# Obtener en: https://cloudinary.com/console/settings/api
# NUNCA exponer este valor en cliente (solo en servidor)
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Carpeta en Cloudinary donde guardar imágenes
# Las imágenes se organizarán en: /buildify/productos/, /buildify/usuarios/, etc.
CLOUDINARY_FOLDER=buildify

# ============================================================================
# SUPABASE - Base de Datos en la Nube (Opcional)
# ============================================================================

# URL de tu proyecto Supabase
# Obtener en: https://app.supabase.com/project/[project-id]/settings/api
SUPABASE_URL=https://your-project.supabase.co

# Clave de servicio de Supabase (service_role key)
# NUNCA usar la anon key en el servidor
# Obtener en: https://app.supabase.com/project/[project-id]/settings/api
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# MAIL (Configuración alternativa con Flask-Mail)
# ============================================================================
# NOTA: Actualmente DESHABILITADO. El sistema usa SendGrid en su lugar.
# Mantener por compatibilidad o futuros cambios.

# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USE_SSL=false
# MAIL_USERNAME=tu_email@gmail.com
# MAIL_PASSWORD=tu_app_password
# MAIL_DEFAULT_SENDER=noreply@buildify.com

# ============================================================================
# URLS PARA DESARROLLO LOCAL vs PRODUCCIÓN
# ============================================================================

# Para desarrollo local:
# BASE_STATIC_URL=/static
# STRIPE_SUCCESS_URL=http://localhost:5000/pagos/success
# STRIPE_CANCEL_URL=http://localhost:5000/pagos/cancel

# Para producción (ej. https://buildify.com):
# BASE_STATIC_URL=https://buildify.com/static
# STRIPE_SUCCESS_URL=https://buildify.com/pagos/success
# STRIPE_CANCEL_URL=https://buildify.com/pagos/cancel

BASE_STATIC_URL=/static

# ============================================================================
# CONFIGURACIÓN ADICIONAL (Opcional)
# ============================================================================

# Log level para desarrollo
# Opciones: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Cantidad máxima de items en carrito (opcional)
# MAX_CARRITO_ITEMS=100

# Tiempo de expiración de token de reset de contraseña (segundos)
# PASSWORD_RESET_TOKEN_EXPIRY=1800

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
#
# 1. NUNCA comitear el archivo ".env" a git
#    Agregarlo a .gitignore si no está ya
#
# 2. Para desarrollo local, puedes usar valores simples
#    Para producción, generar valores seguros:
#    - python -c "import secrets; print(secrets.token_hex(32))"
#
# 3. En producción (Railway/Heroku), agregar variables directamente
#    en el dashboard, NO a través de archivo .env
#
# 4. Cambiar obligatoriamente en producción:
#    - SECRET_KEY
#    - JWT_SECRET_KEY
#    - DB_PASSWORD
#    - Usar claves LIVE de Stripe, no TEST
#
# 5. URLs de Stripe y email deben ser HTTPS en producción
#
# ============================================================================
